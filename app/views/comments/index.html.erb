<div class="container py-5">
<div class="row justify-content-center g-4">
  <% # パンくずリスト風の「戻る」リンク %>
  <div>
    <%= link_to admin_items_path, class: "text-decoration-none text-secondary" do %>
      &laquo; 一覧に戻る
    <% end %>
  </div>

  <div class="col-12 col-lg-5">
    <div class="card shadow-sm border-0 mb-4">
      <div class="card-body p-3">
        <% # 商品詳細 %>
        <div class="d-flex justify-content-between align-items-start mb-1 border-bottom ">
          <div>
            <h4 class="fw-bold"><%= @item.name %></h4>
            <span class="text-muted" style="font-size: 0.8rem;"><%= "ID: #{@item.unique_id}" %></span>
          </div>
          <% if @item.available? %>
            <span class="badge bg-success px-2 py-1">貸出可</span>
          <% elsif @item.borrowed? %>
            <span class="badge bg-danger px-2 py-1">貸出中</span>
          <% else %>
            <span class="badge bg-danger px-2 py-1">メンテ中</span>
          <% end %>
        </div>
  
        <div style="height: 200px; font-size: 6rem;" class="rounded-3 d-flex justify-content-center align-items-center text-secondary">
          <% if @item.persisted? && @item.image.attached? %>
            <%= image_tag @item.image, class: "img-thumbnail border-0 shadow-sm", style: "width: 60%; max-height: 100%; object-fit: contain;" %>
          <% else %>
            <%= image_tag 'default-avatar.png', class: "rounded-lg img-thumbnail mb-3", style: "width: 150px; height: 150px; object-fit: cover;" %>
          <% end %>
        </div>

        <div class="px-1 py-3">
          <div class="fw-bold text-primary mb-2 fs-6">
            <i class="bi bi-info-circle me-2">
            基本情報
            </i>
          </div>
          <dl class="row mb-0 fs-6">
            <dt class="col-sm-3 text-muted mb-2">カテゴリ</dt>
            <dd class="col-sm-9 mb-2"><%= @item.category.name %></dd>

            <dt class="col-sm-3 text-muted mb-2">詳細説明</dt>
            <dd class="col-sm-9 mb-2"><%= simple_format(@item.description, class: "mb-0") %></dd>
            
            <dt class="col-sm-3 text-muted mb-2">登録日</dt>
            <dd class="col-sm-9 mb-2"><%= @item.created_at.strftime("%Y年%m月%d日")%></dd>
          
            <dt class="col-sm-3 text-muted align-self-center mb-0">タグ</dt>
            <dd class="col-sm-9 d-flex flex-wrap gap-1 mb-0">
              <% @item.tags.each do |tag| %>
                <span class="badge bg-secondary rounded-pill"><%= tag.name %></span>
              <% end %>
            </dd>
          </dl>

        </div>
      </div>
    </div>

    <div class="card shadow-sm border-0 ">
      <div class="card-body">
      <%= form_with model: [@item, @comment], local: true do |f| %>
      <%# ▼ コメントの内容フィールド ▼ %>
      <div class="mb-3">
        <div class="d-flex justify-content-between align-items-center">
        <%= f.label :content, class: "form-label" %>
        <% if @comment.errors.include?(:content) %>
          <div style="color: red;" class="mt-3"><%= @comment.errors.full_messages_for(:content).first %></div>
        <% end %>
        </div>
        <%= f.text_area :content, autocomplete: "new-comment", class: "form-control border border-secondary-subtle rounded-3 p-3 shadow-none", style: "height: 120px;" %>
      </div>

      <div class="d-flex gap-2 flex-column flex-md-row">
        <%# ▼ コメントボタン ▼ %>
        <div class="d-grid gap-2 mt-2">
          <%= f.submit "コメントする", rows: [@comment.content.to_s.lines.count, 3].max,class: "btn btn-primary" %>
        </div>
        <%# ▼ キャンセルボタン ▼ %>
        <div class="mt-2 text-center">
          <%= link_to item_comments_path(@item), class: "btn btn-outline-secondary w-100 rounded-pill" do %>
            キャンセル
          <% end %>
        </div>
      </div>
      <% end %>
      </div>
    </div>
  </div>

  <div class="col-12 col-lg-5">
    <div class="card shadow-sm border-0 " style="height: 100%;">
      <div class="card-body" id="comments_list">
        <h3 class="mb-2">コメント一覧<small id="comments_count">(<%= @item.comments.count %>)</small></h3>
        <% @comments.each do |comment| %>
          <div class="shadow-sm border-0 gap-2 rounded-3 px-3 py-2 mb-3 bg-white" id = "comment_box_<%= comment.id %>">
            <div class="d-flex align-items-center mb-2 gap-2">
            
            <% if comment.user.avatar.persisted? && comment.user.avatar.attached? %>
              <%= image_tag comment.user.avatar, class: "img-thumbnail rounded-circle p-0", style: "width: 30px; height: 30px; object-fit: cover;" %>
            <% else %>
              <%= image_tag 'default-avatar.png', class: "img-thumbnail rounded-circle p-0", style: "width: 30px; height: 30px; object-fit: cover;" %>
            <% end %>
            <div>
              <span class="small fw-bold"><%= comment.user.name %></span>
              <span class="small ms-2"><%= comment.updated_at.strftime("%Y年%m月%d日") %></span>
            </div>
          </div>

          <turbo-frame id="<%= dom_id(comment) %>">
          <div class="fs-5 mt-2 text-break">
            <%= simple_format(comment.content) %>
          </div>
          
          <% if comment.user.id == current_user.id %>
            <div class="d-flex gap-2 mt-2">
            <%# 編集ボタン（link_to） %>
            <%= link_to "編集", edit_item_comment_path(@item.id, comment), class: "btn btn-sm btn-outline-primary" %>
            <%# 削除ボタン（button_to） %>
            <%= button_to "削除", item_comment_path(@item.id, comment), method: :delete, data: { turbo_confirm: "本当に削除しますか？" }, class: "btn btn-sm btn-outline-danger" %>
          </div>
          <% end %>
          </turbo-frame>
        </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
</div>
