<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
      
      <h2 class="text-center mb-4">マイページ</h2>

      <%# ▼▼▼ タブのボタン ▼▼▼ %>
      <ul class="nav nav-tabs mb-4" id="myPageTab" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab" aria-controls="profile" aria-selected="true">
            プロフィール
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link" id="account-tab" data-bs-toggle="tab" data-bs-target="#account" type="button" role="tab" aria-controls="account" aria-selected="false">
            アカウント情報
          </button>
        </li>
      </ul>

      <div class="tab-content" id="myPageTabContent">

        <%# ▼▼▼ プロフィール情報の表示 ▼▼▼ %>
        <div class="tab-pane fade show active" id="profile" role="tabpanel" aria-labelledby="profile-tab">
          <div class="card shadow-sm border-0">
            <div class="card-body text-center">
              
              <%# アバター画像 %>
              <div class="mb-4">
                <% if @user.avatar.attached? %>
                  <%= image_tag @user.avatar.variant(resize_to_limit: [150, 150]), class: "rounded-circle img-thumbnail" %>
                <% else %>
                  <%= image_tag 'default-avatar.png', class: "rounded-circle img-thumbnail", style: "width: 150px; height: 150px; object-fit: cover;" %>
                <% end %>
              </div>

              <h3 class="mb-3"><%= @user.name %></h3>

              <div class="d-grid gap-2 mt-4 col-8 mx-auto">
                <%# ★★★ ポイント1：プロフィール編集タブを開くリンク ★★★ %>
                <%# active_tab: 'profile' を渡すことで、編集画面のプロフィールタブが開きます %>
                <%= link_to "プロフィールを編集", edit_user_registration_path(active_tab: 'profile'), class: "btn btn-outline-primary" %>
              </div>

            </div>
          </div>
        </div>

        <%# ▼▼▼ アカウント情報の表示 ▼▼▼ %>
        <div class="tab-pane fade" id="account" role="tabpanel" aria-labelledby="account-tab">
          <div class="card shadow-sm border-0">
            <div class="card-body">
              
              <div class="mb-3 border-bottom pb-3">
                <label class="text-muted small">メールアドレス</label>
                <p class="fs-5 fw-bold mb-0"><%= @user.email %></p>
              </div>

              <div class="mb-3 border-bottom pb-3">
                <label class="text-muted small">パスワード</label>
                <p class="fs-5 fw-bold mb-0">********</p>
              </div>

              <div class="d-grid gap-2 mt-4">
                <%# ★★★ ポイント2：アカウント編集タブを開くリンク ★★★ %>
                <%# active_tab: 'account' を渡すことで、編集画面のアカウントタブが開きます %>
                <%= link_to "メール・パスワードを変更", edit_user_registration_path(active_tab: 'account'), class: "btn btn-outline-danger" %>
              </div>

            </div>
          </div>
        </div>

      </div> 

      <div class="mt-4 text-center">
        <%= link_to "トップページへ戻る", root_path, class: "text-muted text-decoration-none" %>
      </div>

    </div>
  </div>
</div>
