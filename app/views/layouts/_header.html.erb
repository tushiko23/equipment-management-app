<header>
  <%# navbar-expand-md: 画面幅が中サイズ以上ならメニュー展開、それ以下ならハンバーガー %>
  <nav class="navbar navbar-expand-md navbar-light bg-white shadow-sm py-3">
    <div class="container">
      
      <%# ▼ ロゴ部分（仮ロゴデザイン） ▼ %>
      <%= link_to root_path, class: "navbar-brand d-flex align-items-center" do %>
        <%# ロゴアイコン風の装飾 %>
        <span class="rounded-circle bg-primary text-white d-flex justify-content-center align-items-center me-2" style="width: 40px; height: 40px; font-weight: bold; font-size: 1.2rem;">
          SP
        </span>
        <span class="fw-bold text-dark" style="font-family: sans-serif; letter-spacing: 0.5px; font-size: 1.5rem;">
          ToDo <span class="text-primary">App</span>
        </span>
      <% end %>

      <%# ▼ ハンバーガーボタン（スマホ用） ▼ %>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <%# ▼ メニュー項目 ▼ %>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          
          <% if user_signed_in? %>
            <%# --- ログインしている時 --- %>
            <li class="nav-item">
              <span class="nav-link text-secondary me-3">
                ようこそ、<%= current_user.email %> さん
              </span>
            </li>
            <li class="nav-item">
              <%= link_to "マイページ", user_path(current_user.id), class: "nav-link fw-bold" %>
            </li>
            <li class="nav-item">
              <%= link_to "借りているアイテム", lendings_path, class: "nav-link fw-bold" %>
            </li>
            <li class="nav-item ms-md-2 mt-2 mt-md-0">
              <%= button_to "ログアウト", destroy_user_session_path, method: :delete, class: "btn btn-outline-danger w-100 rounded-pill px-4" %>
            </li>

          <% else %>
            <%# --- ログインしていない時 --- %>
            <%# --- 管理者ユーザーのログイン画面で表示 --- %>
            <%# <li class="nav-item">
              <%= #link_to "新規登録", new_user_registration_path, class: "nav-link fw-bold" %>
            <%# </li> %>
            <li class="nav-item mt-2 mt-md-0">
              <%= link_to "ログイン", new_user_session_path, class: "btn btn-primary w-100 rounded-pill px-4 text-white" %>
            </li>
          <% end %>
        </ul>
      </div>
    </div>
  </nav>
</header>
