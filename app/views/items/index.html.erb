<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">備品一覧</h2>
  </div>


  <% # 検索バー %>
  <div class="card shadow-sm mb-5 border-0">
    <div class="card-body p-4">
      <%= search_form_for @q, url: items_path, class: "row g-3" do |f| %>
        <div class="col-md-10">
          <%= f.search_field :name_or_category_name_or_tags_name_cont, value: params.dig(:q, :name_or_category_name_or_tags_name_cont), placeholder: "アイテム名やタグで検索", class: "form-control form-control-lg" %>
        </div>
        <div class="col-md-2">
          <%= f.submit "検索", class: "btn btn-primary w-100 btn-lg" %>
        </div>
      <% end %>
    </div>
  </div>

  <% # パンくずリスト風の「戻る」リンク %>
    <div class="mb-4">
      <%= link_to "javascript:history.back()", class: "text-decoration-none text-secondary" do %>
        &laquo; 戻る
      <% end %>
    </div>

  <% # 備品リスト（グリッド表示）%>
  <h3 class="mb-3"><%= "#{@items.count}件のアイテム" %></h3>
  <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    <% @items.includes(:category).each do |item| %>
      <div class="col">
        <div style="transition: transform 0.2s;" class="card h-100 shadow-sm border-0">
          <% # 画像プレースホルダー（将来的に画像機能を入れたらここを置き換え）%>
          <div style="height: 200px; border-radius: 0.5rem 0.5rem 0 0;" class="bg-light d-flex justify-content-center align-items-center">
            <% if item.persisted? && item.image.attached? %>
              <%= image_tag item.image, class: "img-thumbnail", style: "width: 100%; height: 100%; object-fit: fill;" %>
            <% else %>
              <%= image_tag 'default-avatar.png', class: "rounded-lg img-thumbnail mb-3", style: "width: 150px; height: 150px; object-fit: cover;" %>
            <% end %>
          </div>

          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <% # カテゴリバッジ %>
              <span class="badge bg-light text-dark border">
                <%= item.category.name %>
              </span>

              <% # ステータス表示 %>
              <% if item.available? %>
                <span class="badge bg-success-subtle text-success rounded-pill ">貸出可</span>
              <% elsif item.borrowed? %>
                <span class="badge bg-danger-subtle text-danger rounded-pill">貸出中</span>
              <% else %>
                <span class="badge bg-secondary rounded-pill">メンテ中</span>
              <% end %>
            </div>
            
            <h5 class="card-title fw-bold mt-2"><%= item.name %></h5>
            <p class="card-text text-muted small text-truncate">
              <%= item.description %>
            </p>
            <% item.tags.each do |tag| %>
              <span class="badge bg-secondary rounded-pill fs-7 mb-2"><%= tag.name %></span>
            <% end %>
          </div>

          <div class="card-footer bg-white border-0 pb-3">
            <%= link_to item_path(item), class: "btn btn-primary w-100 rounded-pill" do %>
            詳細を見る
            <% end %>
          </div>

        </div>
      </div>
  <% end %>
  </div>
</div>
