<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
      
      <div class="card shadow-sm border-0">
        <div class="card-body p-4">
          
          <h2 class="text-center mb-4 fw-bold">パスワードをお忘れの方</h2>

          <%= form_with model: resource, scope: resource_name, url: password_path(resource_name), local: true do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>
            <%# ▼ メールアドレス ▼ %>
            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "your@email.com" %>
              <% if resource.errors.include?(:email) %>
                <div style="color: red;" class="mt-3"><%= resource.errors.full_messages_for(:email).first %></div>
              <% end %>
            </div>
            <%# ▼ ログインボタン ▼ %>
            <div class="d-grid gap-2 mt-4">
              <%= f.submit "Send me password reset instructions", class: "btn btn-primary" %>
            </div>
          <% end %>

          <%# ▼ その他のリンク（パスワード忘れ、登録など） ▼ %>
          <div class="mt-4 text-center">
            <%= render "devise/shared/links" %>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>
