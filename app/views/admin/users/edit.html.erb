<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">

      <div class="card shadow-sm border-0">
        <div class="card-body p-4">

          <h2 class="text-center mb-4 fw-bold">ユーザー編集</h2>

          <%= form_with model: [:admin, @user], local: true do |f| %>
            
            <%# ▼ エラーメッセージの表示（Bootstrap対応が必要な場合は別途調整しますが、一旦そのまま配置します） ▼ %>
            <%= render "devise/shared/error_messages", resource: @user %>

            <%# ▼ ユーザーアイコン ▼ %>
            <div class="mb-3 text-center">
              <% if @user.persisted? && @user.avatar.attached? && !@user.errors.include?(:avatar) %>
                <%= image_tag @user.avatar, class: "img-thumbnail mb-3", style: "width: 80%; height: 200px; object-fit: fill;" %>
              <% else %>
                <%= image_tag 'default-avatar.png', class: "rounded-lg img-thumbnail mb-3", style: "width: 200px; height: 200px; object-fit: cover;" %>
              <% end %>
              <% if @user.errors.include?(:avatar) %>
                <div style="color: red;" class="my-3"><%= @user.errors.full_messages_for(:avatar).first %></div>
              <% end %>
              <div class="input-group justify-content-center">
                <%= f.file_field :avatar, class: "form-control", id: "inputGroupFile04" %>
              </div>
              <div class="form-text mt-2">新しいアイコン画像を選択</div>
            </div>

            <%# ▼ ユーザー名 ▼ %>
            <div class="mb-3">
              <%= f.label :name, class: "form-label" %>
              <%= f.text_field :name, autofocus: true, autocomplete: "name", class: "form-control", placeholder: "ユーザー名を入力" %>
              <% if @user.errors.include?(:name) %>
                <div style="color: red;" class="mt-3"><%= @user.errors.full_messages_for(:name).first %></div>
              <% end %>
            </div>

            <%# ▼ メールアドレス ▼ %>
            <div class="mb-3">
              <%= f.label :email, class: "form-label" %>
              <%= f.email_field :email, autocomplete: "email", class: "form-control", placeholder: "your@email.com" %>
              <% if @user.errors.include?(:email) %>
                <div style="color: red;" class="mt-3"><%= @user.errors.full_messages_for(:email).first %></div>
              <% end %>
            </div>

            <%# ▼ スーパー管理者がログインしている時だけ、権限設定エリアを表示 ▼ %>
            <% if current_user.super_admin? %>
              
              <%# 1. 権限（Role）を選ぶプルダウン（super_adminなら全部選べる） %>
              <div class="mb-3">
                <%= f.label :role, class: "form-label" %>
                <%= f.select :role, User.roles_i18n.invert, {}, class: "form-control", id: "role-select" %>
                <% if @user.errors.include?(:role) %>
                  <div style="color: red;" class="mt-3"><%= @user.errors.full_messages_for(:role).first %></div>
                <% end %>
              </div>

              <%# 2. 細かな権限を与えるチェックボックス（adminを作る時用） %>
              <div class="mb-3 " id="permissions-area" >
                <p class="text-muted">※管理者(admin)に個別の権限を与える場合のみチェック</p>
                
                <div class="row">
                  <%# ▼ 管理者に対する権限 ▼ %>
                  <div class="col-md-6">
                    <p class="fw-bold">管理者</p>
                    <div class="form-check">
                      <%= f.check_box :can_create_admin_users, class: "form-check-input" %>
                      <%= f.label :can_create_admin_users, class: "form-label" %>
                    </div>
                    <div class="form-check">
                      <%= f.check_box :can_edit_admin_users, class: "form-check-input" %>
                      <%= f.label :can_edit_admin_users, class: "form-label" %>
                    </div>
                    <div class="form=check">
                      <%= f.check_box :can_delete_admin_users, class: "form-check-input" %>
                      <%= f.label :can_delete_admin_users, class: "form-label" %>
                    </div>
                  </div>
                  <%# ▼ 一般ユーザーに対する権限 ▼ %>
                  <div class="col-md-6">
                    <p class="fw-bold">一般ユーザー</p>
                    <div class="form-check">
                      <%= f.check_box :can_create_general_users, class: "form-check-input" %>
                      <%= f.label :can_create_general_users, class: "form-label" %>
                    </div>
                    <div class="form-check">
                      <%= f.check_box :can_edit_general_users, class: "form-check-input" %>
                      <%= f.label :can_edit_general_users, class: "form-label" %>
                    </div>
                    <div class="form-check">
                      <%= f.check_box :can_delete_general_users, class: "form-check-input" %>
                      <%= f.label :can_delete_general_users, class: "form-label" %>
                    </div>
                  </div>

                </div>
              </div>

            <% else %>
              <%# ▼ adminがログインしている時は、画面には何も出さず、裏側で強制的に「general」として送信する ▼ %>
              <%= f.hidden_field :role, value: "general" %>
            <% end %>

            <%# ▼ 登録ボタン ▼ %>
            <div class="d-grid gap-2 mt-4">
              <%= f.submit "編集する", class: "btn btn-primary" %>
            </div>
            
          <% end %>

          <%# ▼ ログイン画面へのリンクなど ▼ %>
          <div class="mt-4 text-center">
            <%= link_to admin_users_path, class: "btn btn-outline-secondary w-100 rounded-pill" do %>
              ユーザー一覧に戻る
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

