<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold">カテゴリー一覧</h2>
    <% #将来的にここに「備品を登録する」ボタンなどを置けます %>
    <%= link_to new_admin_category_path, class: "btn btn-primary rounded-pill px-4" do %>
      <i class="bi bi-plus-lg"></i>
      カテゴリー登録
    <% end %>
  </div>

  <% # 検索バーのモック（見た目だけ）%>
  <div class="card shadow-sm mb-5 border-0">
    <div class="card-body p-4">
      <form class="row g-3">
        <div class="col-md-10">
          <input type="text" placeholder="備品名やカテゴリで検索..." class="form-control form-control-lg">
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100 btn-lg">検索</button>
        </div>
      </form>
    </div>
  </div>

  <h3 class="mb-3"><%= "#{@categories.count}件のカテゴリー" %></h3>
    <%# 1. テーブル全体を囲んでスマホ対応にする %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      
      <%# 2. 表の見出し（ヘッダー） %>
      <thead>
        <tr>
          <th>番号</th>
          <th>名前</th>
          <th>更新日</th>
          <th>アクション</th>
        </tr>
      </thead>

      <%# 3. 表の中身（データ） %>
      <tbody>
        <% @categories.each_with_index do |category, i| %>
          <tr>
            <td><%= i + 1 %></td>
            <td><%= category.name %></td>
            <td><%= category.updated_at.strftime("%Y-%m-%d") %></td>
            <td>
              <div class="d-flex gap-3 flex-column flex-md-row align-items-center">
                <% if category.items.any? %>
                  <%# アイテムを持っている場合は disabled をつけて押せなくする %>
                  <button class="btn btn-sm btn-secondary disabled">編集不可</button>
                <% else %>
                  <%# アイテムを持っていない場合は通常のリンクを表示 %>
                  <%= link_to "編集する", edit_admin_category_path(category), class: "btn btn-sm btn-outline-primary" %>
                <% end %>
                <%= link_to "削除する", admin_category_path(category), data: { turbo_method: :delete, turbo_confirm: "本当にこの備品を削除しますか？" }, class: "btn btn-sm btn-outline-danger" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
