<% if @my_active_lendings.present? %>
  <div class="mt-2 mb-5">
    <div class="d-flex gap-3 mb-3 align-items-center">
      <h5 class="fw-bold"><i class="bi bi-list-check text-success me-2"></i>現在借りている備品</h5>
      <%= link_to lendings_path, class: "text-decoration-none fw-bold small" do %>
        一覧を確認<i class="bi bi-chevron-right"></i>
      <% end %>
    </div>
    <div class="list-group shadow-sm border-0 rounded-4">
      <% @my_active_lendings.each do |lending| %>
        <div class="list-group-item d-flex justify-content-between align-items-center py-3 px-4 border-bottom">
          <div>
            <h6 class="fw-bold mb-1"><%= lending.item.name %></h6>
            <small class="text-muted">貸出日: <%= lending.created_at.strftime('%m/%d') %></small>
          </div>
          
          <%# 期限に合わせてバッジの色を変える（過ぎていれば赤、今日なら黄色、それ以外は青） %>
          <span class="badge bg-<%= lending.due_at.to_date < Date.current ? 'danger' : (lending.due_at.to_date == Date.current ? 'warning' : 'primary') %> rounded-pill px-3 py-2 shadow-sm">
            <%= lending.due_at.strftime('%m/%d') %> 期限
          </span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<div class="row mt-4">
  
  <%# カード1：現在の借入数 %>
  <div class="col-md-6 mb-4">
    <div class="card shadow-sm border-0 border-start border-primary border-4 h-100 rounded-3">
      <div class="card-body py-4 px-4">
        <div class="d-flex align-items-center mb-3">
          <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
            <i class="bi bi-box-seam text-primary fs-3"></i>
          </div>
          <h6 class="text-muted fw-bold mb-0">現在の借入数</h6>
        </div>

        <h3 class="fw-bold mb-0 text-dark">
          <span class="fs-1 text-primary me-2"><%= @my_active_lendings.count %></span><span class="fs-5 text-muted">アイテム</span>
        </h3>
        
        <div class="mt-3">
          <%= link_to "借りている備品を見る", lendings_path, class: "text-decoration-none fw-bold small text-primary" %>
        </div>

      </div>
    </div>
  </div>

  <%# カード2：返却アラート %>
  <div class="col-md-6 mb-4">
    <div class="card shadow-sm border-0 border-start border-danger border-4 h-100 rounded-3">
      <div class="card-body py-4 px-4">
        <div class="d-flex align-items-center mb-3">
          <div class="bg-danger bg-opacity-10 p-3 rounded-circle me-3">
            <i class="bi bi-exclamation-triangle text-danger fs-3"></i>
          </div>
          <h6 class="text-muted fw-bold mb-0">本日が返却期限</h6>
        </div>

        <h3 class="fw-bold mb-0 text-dark">
          <span class="fs-1 text-danger me-2"><%= @my_active_lendings.count { |item| item.due_at.to_date == Date.current } %></span><span class="fs-5 text-muted">アイテム</span>
        </h3>
        <div class="mt-3">
          <span class="text-muted small">※期限を過ぎているものがないか確認しましょう</span>
        </div>
      </div>
    </div>
  </div>
</div>

<%# アクションボタン %>
<div class="d-flex flex-column flex-md-row justify-content-center gap-3 mt-4 mb-5">
  <%= link_to items_path, class: "btn btn-primary btn-lg rounded-pill px-5 shadow-sm fw-bold" do %>
    <i class="bi bi-card-list me-2"></i>備品を探す
  <% end %>

  <%= link_to lendings_path, class: "btn btn-outline-primary btn-lg rounded-pill px-5 shadow-sm fw-bold" do %>
    <i class="bi bi-card-list me-2"></i>一覧を見る
  <% end %>
</div>
