<%# 管理者からの未読通知 %>
<% if @unread_notifications.present? %>
  <div class="row mb-4">
    <div class="col-12">
      <div class="card shadow-sm border-0 border-start border-warning border-4 rounded-3 bg-warning bg-opacity-10">
        <div class="card-body py-3 px-4">
          <div class="d-flex align-items-center gap-3 flex-wrap mb-3">
            <h6 class="fw-bold text-warning-emphasis mb-0">
              <i class="bi bi-bell-fill me-2"></i>管理者からの重要なお知らせ（<%= @unread_notifications.count %>件）
            </h6>
            <%= link_to lendings_path, class: "text-warning text-decoration-none fw-bold small d-none d-md-inline-block" do %>
              一覧を確認 <i class="bi bi-chevron-right"></i>
            <% end %>
            <div class="w-100 text-center d-md-none mt-1">
              <%= link_to lendings_path, class: "btn btn-sm btn-warning rounded-pill fw-bold px-5 py-2 shadow-sm text-nowrap" do %>
                <i class="bi bi-card-list me-1"></i>一覧を確認
              <% end %>
            </div>
          </div>

          <div class="list-group list-group-flush bg-transparent">
            <% @unread_notifications.each do |notification| %>
              <div class="list-group-item bg-transparent px-0 border-warning border-opacity-25 d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 py-3">
                <div>
                  <p class="mb-1 fw-bold text-dark"><%= notification.message %></p>
                  <small class="text-muted"><%= notification.created_at.strftime('%m/%d %H:%M') %></small>
                </div>
                <div class="w-100" style="max-width: 500px;">
                  <%= form_with(model: notification, local: true, class: "d-flex flex-column flex-md-row gap-2 w-100") do |f| %>
                    <%= f.text_field :reply_message, class: "form-control rounded-pill border-warning bg-white w-100", placeholder: "返信を入力（例：明日必ず返却します！）", required: true %>
                    <%= f.button type: "submit", class: "btn btn-warning rounded-pill px-4 fw-bold shadow-sm text-nowrap flex-shrink-0" do %>
                      <i class="bi bi-send-fill me-1"></i>返信して確認
                    <% end %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>

        </div>
      </div>
    </div>
  </div>
<% end %>


